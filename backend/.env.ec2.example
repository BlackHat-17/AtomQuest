# ─────────────────────────────────────────────────────────────────────────────
# Backend Environment Variables — AWS EC2 Production
# Copy this file to backend/.env.production and fill in all values marked <...>
# DO NOT commit the filled .env.production to git.
# ─────────────────────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# These are used by docker-compose.yml via ${POSTGRES_*} vars.
# The DATABASE_URL is assembled automatically in docker-compose.yml using
# the internal Docker network hostname "postgres".
# Only set this manually if you are using an external DB (e.g., AWS RDS).
# DATABASE_URL=postgresql://goalportal:<password>@postgres:5432/goalportal

# Postgres credentials (used by docker-compose.yml)
POSTGRES_USER=goalportal
POSTGRES_PASSWORD=<generate-a-strong-password-here>
POSTGRES_DB=goalportal

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis password (leave blank to disable auth — not recommended for prod)
REDIS_PASSWORD=<generate-a-strong-redis-password>

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=<generate-at-least-48-char-random-string>
JWT_REFRESH_SECRET=<generate-at-least-48-char-random-string>

# ── CORS / Frontend URL ───────────────────────────────────────────────────────
# Set to your EC2 public IP or domain name (with http:// or https://)
FRONTEND_URL=http://<EC2_PUBLIC_IP_OR_DOMAIN>

# ── Microsoft Entra ID (Azure AD) SSO — optional ──────────────────────────────
# Leave blank to disable SSO
# AAD_TENANT_ID=
# AAD_CLIENT_ID=
# AAD_CLIENT_SECRET=
# AAD_GROUP_ADMIN=
# AAD_GROUP_MANAGER=
# AAD_GROUP_EMPLOYEE=

# ── Email (SMTP) — optional ───────────────────────────────────────────────────
# Leave blank to disable email notifications
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

# ── Microsoft Teams Webhooks — optional ───────────────────────────────────────
# TEAMS_WEBHOOK_URL=

# ── Gemini AI — optional ──────────────────────────────────────────────────────
# GEMINI_API_KEY=
