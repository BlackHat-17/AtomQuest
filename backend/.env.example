# Database
DATABASE_URL=postgresql://goalportal:goalportal_secret@localhost:5432/goalportal

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (use long random strings in production)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long

# Server
PORT=3000

# CORS — frontend origin
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development

# Microsoft Entra ID (Azure AD) SSO — optional, SSO is disabled when absent
AAD_TENANT_ID=your-tenant-id
AAD_CLIENT_ID=your-client-id
AAD_CLIENT_SECRET=your-client-secret
AAD_GROUP_ADMIN=admin-group-object-id
AAD_GROUP_MANAGER=manager-group-object-id
AAD_GROUP_EMPLOYEE=employee-group-object-id

# Email notifications via SMTP — all optional; email is disabled when SMTP_HOST is absent
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@goalportal.com

# Microsoft Teams notifications — optional; Teams is disabled when absent
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
