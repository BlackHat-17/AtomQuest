{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:prod": "tsup src/index.ts --format cjs --outDir dist --no-splitting --external bcryptjs",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:clear": "npx tsx prisma/clear-achievements.ts",
    "db:reset-data": "npx tsx prisma/clear-achievements.ts && npx tsx prisma/seed.ts",
    "db:check-status": "npx tsx prisma/check-goal-status.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.5.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.16",
    "@types/passport": "^1.0.16",
    "@types/supertest": "^6.0.2",
    "fast-check": "^3.23.2",
    "nodemon": "^3.1.7",
    "prisma": "^5.19.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.3",
    "vitest": "^2.1.9"
  }
}
